{
    "$schema": "https://playground.wordpress.net/blueprint-schema.json",
    "landingPage": "/wp-admin/admin.php?page=neolite-birthday-bash",
    "login": true,
    "steps": [
        {
            "step": "installPlugin",
            "pluginData": {
                "resource": "wordpress.org/plugins",
                "slug": "woocommerce"
            },
            "options": { "activate": true }
        },
        {
            "step": "setSiteOptions",
            "options": {
                "woocommerce_allow_tracking": "no",
                "woocommerce_onboarding_profile": "{}",
                "woocommerce_setup_jetpack_post_install": "no",
                "woocommerce_task_list_hidden_lists": "[\"setup\"]",
                "woocommerce_admin_install_timestamp": "1715150000",
                "woocommerce_default_country": "US:NY",
                "woocommerce_currency": "USD"
            }
        },
        {
            "step": "importWxr",
            "file": {
                "resource": "url",
                "url": "https://raw.githubusercontent.com/woocommerce/woocommerce/trunk/plugins/woocommerce/sample-data/sample_products.xml"
            }
        },
        {
            "step": "installPlugin",
            "pluginData": {
                "resource": "wordpress.org/plugins",
                "slug": "birthday-bash"
            },
            "options": { "activate": true }
        },
        {
            "step": "runPHP",
            "code": "<?php require_once '/wordpress/wp-load.php'; wp_insert_post(['post_title' => 'Birthday Form Demo', 'post_content' => '[birthday_bash_form]', 'post_status' => 'publish', 'post_type' => 'page']); ?>"
        }
    ]
}
